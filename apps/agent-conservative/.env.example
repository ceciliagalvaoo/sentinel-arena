NETWORK=devnet
SOLANA_RPC_URL=https://api.devnet.solana.com
TXLINE_API_ORIGIN=https://txline-dev.txodds.com
TXLINE_PROGRAM_ID=6pW64gN1s2uqjHkn1unFeEjAwJkPGHoppGvS715wyP2J
WALLET_KEYPAIR_PATH=./secrets/agent-conservative-wallet.json
AGENT_ID=agent-conservative
SENSITIVITY_MULTIPLIER=3.0
WINDOW_SECONDS=180
WARMUP_READINGS=30
DATABASE_URL=postgres://postgres:devpassword@localhost:5432/sentinel

# guest JWT and apiToken are obtained at runtime by scripts/setup-subscription.ts
# and persisted automatically -- do not configure manually here

# Replay mode (optional) -- set REPLAY_FIXTURE_ID to run against recorded
# data (scripts/seed-replay-data.ts) instead of the live TxLINE stream.
# Without this variable, the agent runs in LIVE mode by default.
# REPLAY_FIXTURE_ID=18209181
# REPLAY_SPEED_MULTIPLIER=1
# REPLAY_MAX_EVENTS=
